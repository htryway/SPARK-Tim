<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#0F1C2E"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Title -->
    <TextView
        android:text="Spark Chat"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#D9D9E3"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Chat Area -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/messageText"
            android:text="Bot: Hi Cora! What time of day is it? 😊"
            android:textColor="#C7C9D3"
            android:textSize="18sp"
            android:lineSpacingExtra="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </ScrollView>

    <!-- Input + Send -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/inputTime"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="Type time of day..."
            android:textColor="#FFFFFF"
            android:textColorHint="#9AA0A6"
            android:backgroundTint="#9AA0A6"
            android:padding="10dp"/>

        <Button
            android:id="@+id/sendBtn"
            android:text="Send"
            android:textAllCaps="false"
            android:layout_marginStart="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- ✅ Reset Button (THIS is what you want) -->
    <Button
        android:id="@+id/resetBtn"
        android:text="Reset Chat"
        android:textAllCaps="false"
        android:textColor="#000000"
        android:layout_marginTop="10dp"
        android:backgroundTint="#BFAEDB"
        android:layout_width="match_parent"
        android:layout_height="55dp"/>

</LinearLayout>